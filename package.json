{
  "name": "jarvis-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "e2e": "node tests/e2e/runE2E.js",
    "e2e:local": "node tests/e2e/runE2E.js --local",
    "lint": "node scripts/lint-syntax.js",
    "review": "node scripts/review-coverage.js && node scripts/review-security.js && node scripts/review-logic.js",
    "review:coverage": "node scripts/review-coverage.js",
    "review:security": "node scripts/review-security.js",
    "review:logic": "node scripts/review-logic.js",
    "mcp:server": "node mcp-server.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/archive/"
    ],
    "collectCoverageFrom": [
      "server.js",
      "agents/**/*.js",
      "services/**/*.js",
      "controllers/**/*.js",
      "routes/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 54,
        "branches": 44,
        "functions": 51,
        "lines": 57
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NadavZ-sketch/myassistant-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/NadavZ-sketch/myassistant-backend/issues"
  },
  "homepage": "https://github.com/NadavZ-sketch/myassistant-backend#readme",
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pinecone-database/pinecone": "^7.1.0",
    "@supabase/supabase-js": "^2.102.1",
    "axios": "^1.14.0",
    "chart.js": "^4.5.1",
    "chokidar": "^3.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "google-tts-api": "^2.0.2",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "simple-git": "^3.36.0",
    "ws": "^8.18.0"
  }
}
