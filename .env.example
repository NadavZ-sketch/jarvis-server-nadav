# ─── Required ────────────────────────────────────────────────────────────────
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Optional ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=
OLLAMA_URL=
OBSIDIAN_VAULT_PATH=
OPENROUTER_API_KEY=

# ─── Manus autonomous agent ───────────────────────────────────────────────────
# Get your key at: manus.im → Settings → Integration → Build with Manus API
MANUS_API_KEY=

# Agent profile: manus-1.5 | manus-1.5-lite | manus-1.6  (default: manus-1.5)
MANUS_MODEL=manus-1.5

# Base URL — change only if Manus releases a new API version
MANUS_BASE=https://api.manus.ai/v1

# Auth header name — 'API_KEY' (official docs) or 'Authorization' (some accounts)
MANUS_AUTH_HEADER=API_KEY

# How long to wait for a Manus task to complete, in ms (default: 600000 = 10 min)
MANUS_TIMEOUT_MS=600000

# Max polling interval in ms (default: 15000 = 15s)
MANUS_POLL_MAX_MS=15000

# Smart auto-routing: set to 'off' to disable sending complex requests to Manus automatically
# MANUS_AUTOROUTE=off

# ─── Manus token-offload switches ─────────────────────────────────────────────
# Set any of these to 'true' to run the LLM analysis step via Manus instead of
# the cloud LLM chain. Useful when Groq/DeepSeek/Gemini quota is exhausted.
# All default to off; local probe/data collection still runs locally.
#
# MANUS_OFFLOAD_SECURITY=true    # security scan (saves ~15k tokens/scan)
# MANUS_OFFLOAD_E2E=true         # e2e report narrative (saves ~3k tokens/run)
# MANUS_OFFLOAD_INSIGHT=true     # insight analysis (saves ~3k tokens/call)
# MANUS_OFFLOAD_CODE_ERROR=true  # code error analysis (saves ~3k tokens/scan)
